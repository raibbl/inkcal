# Google OAuth2 client (Google Cloud Console -> APIs & Services -> Credentials)
# Used with a long-lived refresh token so the server can read your calendar
# without an interactive browser login on every request.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Calendar to read events from (defaults to "primary" if unset)
GOOGLE_CALENDAR_ID=you@example.com

# Shared secret the ESP32 sends as: Authorization: Bearer <ESP32_SECRET_KEY>
ESP32_SECRET_KEY=

# Shared secret sent by any phone/automation client as: x-webhook-secret: <PHONE_WEBHOOK_SECRET>
PHONE_WEBHOOK_SECRET=

# Coordinates for the weather subheader (Open-Meteo, no API key needed).
# Fixed on purpose - the desk doesn't move, so this stays correct even
# when the app runs on Vercel (IP-geolocating the serverless function
# would report the datacenter's location, not the desk's). Omit either
# one to skip weather entirely.
WEATHER_LAT=
WEATHER_LON=

# IANA timezone for all displayed times (e.g. America/Chicago). Fixed for
# the same reason as the weather coords - the server's own timezone
# differs by environment (UTC on Vercel, local time in dev), so relying
# on it would show the wrong time on the physical display. Defaults to
# UTC if unset.
DISPLAY_TIMEZONE=
